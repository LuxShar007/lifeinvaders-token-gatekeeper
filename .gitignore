# =================================================================
# LifeInvaders Gatekeeper Git Exclusion Architecture
# =================================================================

# Block python environments and dependencies
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Block local LLM models and weights
models/
*.gguf
.ollama/

# Local environment keys and variables
.env
*.local
.gitignore

# Archit's Output validation data 
# (Keep your tasks file, but ignore your generated runtime output results)
mock_io/output/results.json

# Docker system logs
*.log